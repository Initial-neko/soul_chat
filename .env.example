# DeepSeek API 配置
DEEPSEEK_API_KEY=your-api-key-here

# 网络代理配置（可选，需要代理时设置）
# HTTP_PROXY=http://127.0.0.1:7890
# HTTPS_PROXY=http://127.0.0.1:7890

# STT 配置
# STT 模式: "local" (faster-whisper) 或 "api" (OpenAI Whisper API)
# local 模式免费但需要下载模型，api 模式需要 API key
STT_MODE=local
# local 模式下的模型大小: tiny/base/small/medium/large (中文推荐 small)
# api 模式此参数无效
WHISPER_MODEL=small
# OpenAI API key (仅 api 模式需要)
OPENAI_API_KEY=your-openai-api-key-here

# TTS 配置
# edge-tts 中文语音推荐: xiaoxiao, xiaoyi, yunxi, yunyang
# 或直接使用: zh-CN-XiaoxiaoNeural
TTS_VOICE=xiaoxiao
# 语速调整: "+10%" 表示快 10%, "-10%" 表示慢 10%
TTS_RATE=+0%
# 语调调整: "+10Hz" 或 "-10Hz"
TTS_PITCH=+0Hz
# 音量调整: "+10%" 或 "-10%"
TTS_VOLUME=+0%

# 记忆配置
# 滑动窗口保留轮数
MEMORY_WINDOW=20